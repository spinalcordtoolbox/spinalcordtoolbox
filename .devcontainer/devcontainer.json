{
  "name": "Spinal Cord Toolbox",

  // Use a Dockerfile for custom image
  "build": {
    "dockerfile": "../Dockerfile"
  },

  // Features to install
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
    "ghcr.io/miguelrodo/devcontainerfeatures/apptainer:1": {}
  },

  // VSCode extensions
  "customizations": {
    "vscode": {
      "extensions": [
        // Python development
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",

        // Testing
        "ms-python.pytest",

        // Data science & Jupyter
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.jupyter-renderers",

        // Linting and formatting
        "ms-python.flake8",

        // Documentation
        "lextudio.restructuredtext",

        // Git
        "mhutchie.git-graph",

        // General productivity
        "ms-vscode-remote.remote-containers"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/root/sct/python/envs/venv_sct/bin/python",
        "python.terminal.activateEnvironment": true,
        "python.terminal.activateEnvInCurrentTerminal": true,
        "python.linting.enabled": true,
        "python.linting.flake8Enabled": true,
        "python.formatting.provider": "none",
        "[python]": {
          "editor.defaultFormatter": "ms-python.python",
          "editor.formatOnSave": false,
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
          }
        },
        "pytest.showTerminalOnTestStart": false,
        "python.testing.pytestEnabled": true,
        "python.testing.unittestEnabled": false,
        "notebooks.codeLens.enabled": true,
        "jupyter.notebookFileRoot": "${workspaceFolder}"
      }
    }
  },

  // Environment variables
  "remoteEnv": {
    "PATH": "/root/sct/bin:/root/sct/python/envs/venv_sct/bin:/root/sct/python/bin:${containerEnv:PATH}",
    "SCT_DIR": "/root/sct"
  },

  "containerEnv": {
    "PROMPT_COMMAND": "history -a",
    "HISTFILE": "/commandhistory/.bash_history"
  },

  "mounts": [
    "source=spinalcordtoolbox-bashhistory,target=/commandhistory,type=volume"
  ],

  // Run post-creation command to install dependencies
  "postCreateCommand": "cp /root/sct/python/etc/profile.d/* /etc/profile.d/. && pip install -e .[docs]",

  // Forward ports if needed (e.g., for Jupyter or local development server)
  "forwardPorts": [
    8888  // Jupyter notebook
  ],

  // Container execution settings
  "runArgs": [
    "--init",
    "--security-opt",
    "label=disable,seccomp=unconfined,apparmor=unconfined",
    "--cap-add",
    "SYS_ADMIN",
    "--cap-add",
    "SYS_CHROOT"
  ],

  "privileged": true
}
